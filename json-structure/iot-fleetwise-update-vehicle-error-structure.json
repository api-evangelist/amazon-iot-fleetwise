    "code": {
      "allOf": [
        {
          "$ref": "#/components/schemas/number"
        },
        {
          "description": "The relevant HTTP error code (400+)."
        }
      ]
    },
    "message": {
      "allOf": [
        {
          "$ref": "#/components/schemas/string"
        },
        {
          "description": "A message associated with the error."
        }
      ]
